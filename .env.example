# .env.example — copiar pra .env.local (gitignored) e preencher.
# Variáveis opcionais do plugin marketing-doma.

# Webhook pra notificar equipe quando cron-discover detecta modelos novos.
# Suporta Discord (discord.com/api/webhooks/...) OU Slack (hooks.slack.com/services/...)
# DOMA_WEBHOOK_URL=https://discord.com/api/webhooks/XXX/YYY

# Bypass do hook git-guardrails (push) — só usar em situações pontuais.
# Whitelist persistente: ~/.claude/git-push-whitelist
# CLAUDE_ALLOW_GIT_PUSH=1
