{
  "name": "marketing-doma-cli",
  "version": "0.1.47",
  "description": "CLI local do projeto marketing-doma — npm install marketing-doma-cli (sem -g). Download tarball + setup .claude/.cursor/remotion-doma.",
  "bin": {
    "marketing-doma": "bin/marketing-doma.js"
  },
  "main": "bin/marketing-doma.js",
  "scripts": {
    "postinstall": "node postinstall.js",
    "doma:install": "marketing-doma install",
    "doma:update": "marketing-doma update",
    "doma:status": "marketing-doma status",
    "doma:setup": "node .claude/plugins/marketing-doma/scripts/lib/install-deps.mjs",
    "doma:export": "marketing-doma export"
  },
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "tar": "^7.4.3"
  },
