  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rafael-senter/marketing-doma.git",
    "directory": "cli"
  },
  "bugs": {
    "url": "https://github.com/rafael-senter/marketing-doma/-/issues"
  },
  "homepage": "https://github.com/rafael-senter/marketing-doma#readme"
